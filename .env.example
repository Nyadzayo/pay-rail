# PayRail Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Peach Payments Sandbox
PEACH_SANDBOX_API_KEY=
PEACH_SANDBOX_ENTITY_ID=
PEACH_SANDBOX_WEBHOOK_SECRET=

# Startbutton Sandbox
STARTBUTTON_SANDBOX_API_KEY=
STARTBUTTON_SANDBOX_WEBHOOK_SECRET=

# General
PAYRAIL_LOG_LEVEL=info
